# API configuration (12-factor). Copy to `.env` for local dev.
# Never commit real secrets — `.env` is gitignored.

# Postgres connection (matches the dev-loop compose.yaml defaults).
DATABASE_URL=postgresql://finance:finance@localhost:5432/finance

# Comma-separated origins allowed by CORS (the front dev server).
CORS_ALLOW_ORIGINS=http://localhost:5173

# How long the /health readiness query may take before reporting the db down.
DB_READINESS_TIMEOUT_SECONDS=2
